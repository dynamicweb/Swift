@inherits ViewModelTemplate<FavoriteListListViewModel>
@using Dynamicweb.Frontend
@using Dynamicweb.Rendering
@using Dynamicweb.Ecommerce.Frontend
@using Dynamicweb.Ecommerce.ProductCatalog

@{
    var baseUrl = SearchEngineFriendlyURLs.GetFriendlyUrl($"default.aspx?ID={Pageview?.Page?.ID}");
}

<div data-swift-favorites-list>
    <header class="hstack gap-3 mb-4">
        <h1 class="h4 mb-0 flex-fill">@(Pageview?.Page?.GetDisplayName() ?? string.Empty)</h1>

        <button type="button" class="btn btn-sm btn-primary hstack gap-2 ms-auto py-2 px-3" data-dw-button
            hx-trigger="click"
            hx-get="@(baseUrl)"
            hx-vals='{"LayoutTemplate": "/Designs/Swift-v2/eCom/CustomerExperienceCenter/Favorites/Modals/CreateFavoriteListModal.cshtml"}'
            hx-target="main"
            hx-swap="beforeend">
            <span class="icon text-opacity-50">
                @ReadFile("/Files/Images/Icons/plus.svg")
            </span>
            @Translate("New list")
        </button>

    </header>

    @if (Model.FavoriteLists is not null)
    {
        if (Model.FavoriteLists.Count > 0)
        {
            @RenderPartial("/Designs/Swift-v2/eCom/CustomerExperienceCenter/Favorites/Layouts/Table.cshtml")
        }
        else
        {
            <div class="card">
                <div class="card-body text-center">

                    <div class="d-grid align-items-center justify-content-center rounded-circle m-auto" style="width:4rem;aspect-ratio:1;background-color:rgba(var(--bs-body-color-rgb), .0275);">
                        <span class="icon fs-4 text-muted">
                            @ReadFile("/Files/Images/Icons/heart.svg")
                        </span>
                    </div>

                    <div class="mt-3">@Translate("It looks like you do not have any favorites yet")</div>
                    <p class="fs-7 text-muted">@Translate("Save and arrange the best things here until you are ready for them")</p>

                    <button type="button" class="btn btn-primary hstack gap-2 mx-auto mt-3" data-dw-button
                        hx-trigger="click"
                        hx-get="@(baseUrl)"
                        hx-vals='{"LayoutTemplate": "/Designs/Swift-v2/eCom/CustomerExperienceCenter/Favorites/Modals/CreateFavoriteListModal.cshtml"}'
                        hx-target="main"
                        hx-swap="beforeend">
                        <span class="icon">
                            @ReadFile("/Files/Images/Icons/plus.svg")
                        </span>
                        @Translate("New list")
                    </button>
                </div>
            </div>
        }
    }

    @if (Model.PageCount > 1)
    {
        <div class="hstack justify-content-between mt-3">
            <div class="text-muted fs-7">
                @Translate("Showing page") @(Model.CurrentPage) @Translate("of") @(Model.PageCount)
            </div>

            <div class="hstack gap-2">
                <button type="submit" class="btn btn-outline-secondary text-body hstack p-2" name="PageNum" value="@(Model.CurrentPage - 1)" data-dw-button disabled="@(Model.CurrentPage == 1)" hx-get="@(baseUrl)" hx-target="[data-swift-favorites-list]" hx-select="[data-swift-favorites-list]" hx-swap="outerHTML" hx-replace-url="true">
                    <span class="icon">
                        @ReadFile("/Files/Images/Icons/chevron-left.svg")
                    </span>
                </button>
                <button type="submit" class="btn btn-outline-secondary text-body hstack p-2" name="PageNum" value="@(Model.CurrentPage + 1)" data-dw-button disabled="@(Model.CurrentPage == Model.PageCount)" hx-get="@(baseUrl)" hx-target="[data-swift-favorites-list]" hx-select="[data-swift-favorites-list]" hx-swap="outerHTML" hx-replace-url="true">
                    <span class="icon">
                        @ReadFile("/Files/Images/Icons/chevron-right.svg")
                    </span>
                </button>
            </div>
        </div>
    }
</div>