@inherits ViewModelTemplate<FavoriteListListViewModel>
@using Dynamicweb.Frontend
@using Dynamicweb.Rendering
@using Dynamicweb.Ecommerce.Frontend
@using Dynamicweb.Ecommerce.ProductCatalog

@{
    var baseUrl = SearchEngineFriendlyURLs.GetFriendlyUrl($"default.aspx?ID={Pageview?.Page?.ID}");
}

<div class="card overflow-hidden">
    <div class="table-responsive">
        <table class="table table-md table-hover mb-0 align-middle fs-7" style="--bs-table-color: var(--bs-body-color);">
            <thead style="--bs-table-bg: rgba(var(--bs-body-color-rgb), .0275); --bs-table-color: rgba(var(--bs-body-color-rgb), 0.5);">
                <tr>
                    <th>@Translate("Name")</th>
                    <th>@Translate("Products")</th>
                    <th>@Translate("Created")</th>
                    <th>@Translate("Actions")</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var favoriteList in Model.FavoriteLists)
                {
                    <tr class="position-relative">
                        <td class="text-wrap" style="max-inline-size: 10rem;">
                            <div class="hstack lh-1">
                                <a href="@(baseUrl)?FavoriteListId=@(favoriteList.Id)" class="text-decoration-none text-decoration-underline-hover">
                                    <span class="lh-1">@(!string.IsNullOrEmpty(favoriteList.Name) ? favoriteList.Name : (Translate("Untitled") + " #" + favoriteList.Id))</span>
                                </a>
                                @if(favoriteList.IsDefault) { <span class="badge bg-secondary-subtle text-reset ms-2 lh-1">@Translate("Default")</span> }
                            </div>
                            <div class="fs-8 text-muted" style="max-inline-size: 15rem; text-wrap: nowrap; overflow: hidden; text-overflow: ellipsis;">@(!string.IsNullOrEmpty(favoriteList.Description) ? favoriteList.Description : "-")</div>
                        </td>
                        <td>
                            <div class="d-grid gap-1" style="grid-template-columns: repeat(4, 2rem);">
                                @if (favoriteList.ProductList.Products.Any())
                                {
                                    foreach (var product in favoriteList.ProductList.Products.Take(3))
                                    {
                                        @if(product?.DefaultImage?.TryGetImageFileViewModel(out var image) is true)
                                        {
                                            <div class="d-flex img-thumbnail" style="aspect-ratio: 1;">
                                                <img class="img-fluid mh-100 m-auto" src="@(image?.ToGetImage(new(){Height = 22, Width = 22, Ratio = "1/1", Crop = Dynamicweb.Imaging.ImageHandling.CropMode.KeepAspectRatio }))" alt="@product?.Name" loading="lazy" decoding="async">
                                            </div>
                                        }
                                    }
                                    if(favoriteList.ProductList.Products.Count > 3)
                                    {
                                        
                                        <span class="icon text-muted m-auto d-flex align-items-center justify-content-center gap-0 fs-8 p-0 fw-semibold">
                                            @ReadFile("/Files/Images/Icons/plus.svg")
                                            @(favoriteList.ProductList.Products.Count - 3)
                                        </span>
                                        
                                    }
                                }
                            </div>
                        </td>
                        <td>
                            <div class="vstack">
                                @(favoriteList?.Created?.ToString(Pageview?.Area?.CultureInfo?.DateTimeFormat?.ShortDatePattern) ?? "-")
                                <span class="text-muted fs-8">
                                    @(favoriteList?.Created?.ToString(Pageview?.Area?.CultureInfo?.DateTimeFormat?.ShortTimePattern) ?? "")
                                </span>
                            </div>
                        </td>
                        <td>
                            <button type="button" class="btn btn-sm btn-outline-secondary border-0 text-reset hstack p-2 z-2" data-dw-button type="button" data-bs-toggle="dropdown" aria-expanded="false" data-bs-popper-config='{"strategy":"fixed", "placement":"bottom-end"}'>
                                <span class="icon">
                                    @ReadFile("/Files/Images/Icons/ellipsis.svg")
                                </span>
                            </button>
                            <ul class="dropdown-menu dropdown-menu-shadow fs-7">
                                <li>
                                    <button type="button" class="dropdown-item hstack gap-2"
                                        hx-get="/dwapi/ecommerce/favorites/lists/@(favoriteList?.Id)"
                                        hx-headers='{"x-dw-template": "/Designs/Swift-v2/eCom/CustomerExperienceCenter/Favorites/Modals/RenameFavoriteListModal.cshtml", "x-dw-culture": "@Pageview?.Area?.CultureInfo?.Name", "accept": "text/html"}'
                                        hx-target="main"
                                        hx-swap="beforeend"
                                        hx-ext="swift-auth">
                                        <span class="icon fs-6">
                                            @ReadFile("/Files/Images/Icons/pen.svg")
                                        </span>
                                        @Translate("Rename")
                                    </button>
                                </li>
                                <li>
                                    <button type="button" class="dropdown-item hstack gap-2"
                                        hx-get="?favoritecmd=favoritelistsetdefault&userid=@(Pageview?.User?.ID)&favoritelistid=@(favoriteList?.Id)"
                                        hx-select="[data-swift-favorites-list]"
                                        hx-target="[data-swift-favorites-list]"
                                        hx-swap="outerHTML"
                                        hx-replace-url="false"
                                        disabled="@(favoriteList?.IsDefault ?? false)"
                                        >
                                        <span class="icon fs-6">
                                            @ReadFile("/Files/Images/Icons/star.svg")
                                        </span>
                                        @Translate("Set as default")
                                    </button>
                                </li>
                                <li>
                                <hr class="dropdown-divider my-1">
                                </li>                   
                                <li>
                                    <button type="button" class="dropdown-item hstack gap-2 text-danger"
                                        hx-get="?favoritecmd=favoritelistremove&userId=@(Pageview?.User?.ID)&favoriteListId=@(favoriteList?.Id)"
                                        hx-confirm="@Translate("Are you sure you want to delete this list?")"
                                        hx-select="[data-swift-favorites-list]"
                                        hx-target="[data-swift-favorites-list]"
                                        hx-swap="outerHTML"
                                        hx-replace-url="false"
                                        >
                                        <span class="icon fs-6">
                                            @ReadFile("/Files/Images/Icons/trash-can.svg")
                                        </span>
                                        @Translate("Delete")
                                    </button>
                                </li>                                
                            </ul>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>