@inherits Dynamicweb.Rendering.ViewModelTemplate<ParagraphViewModel>
@using Dynamicweb.Frontend

@{
    AddScript("/Files/Templates/Designs/Swift-v2/Paragraph/Swift-v2_CustomerCenter_Dashboard/Assets/widget.js");

    var widgetTitle = Model?.Item?.GetString("Title") ?? Translate("Pending quotes");
    var baseUrl = Model?.Item?.TryGetLink("BaseLink", out var baseLink) ?? false ? baseLink.Url : null;
}

<div class="card" style="--swift-content-padding: 1.25rem;">
    <div class="card-body">
        <div class="hstack gap-3 mb-3">
            <div class="hstack gap-2 flex-grow-1">
                <div class="d-grid p-2 rounded-2" style="background-color: color-mix(in srgb, var(--bs-orange) 10%, transparent);">
                    <span class="icon fs-5" style="color: var(--bs-orange);">@ReadFile("/Files/Images/Icons/file-lines.svg")</span>
                </div>
                <h2 class="h6 mb-0 fw-semibold">@(widgetTitle)</h2>
            </div>
            @if (baseUrl is not null)
            {
                <a class="fs-8 fw-semibold text-decoration-none text-muted text-decoration-underline-hover" href="@(baseUrl)">@Translate("View all") →</a>
            }
        </div>
        <div data-swift-htmx-widget="@(Model?.ID)"
            hx-get="/dwapi/ecommerce/orders/search?Type=quote&PageSize=5&Page=1&SortBy=CreatedAt&SortOrder=Desc" 
            hx-headers='{"x-dw-template": "/Designs/Swift-v2/Paragraph/Swift-v2_CustomerCenter_Dashboard/ResponseTemplates/List_Quotes.cshtml", "accept": "text/html"}'
            hx-vals='{"baseUrl": "@(baseUrl)"}'
            hx-ext="swift-auth"
            hx-trigger="swift:load once"
            hx-swap="innerHTML">
            <div class="spinner-border spinner-border-sm" role="status">
                <span class="visually-hidden">Loading...</span>
            </div>
        </div>
    </div>
</div>