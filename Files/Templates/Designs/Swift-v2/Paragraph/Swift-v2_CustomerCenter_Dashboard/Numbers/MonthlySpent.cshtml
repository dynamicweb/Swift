@inherits ViewModelTemplate<OrderListViewModel>
@using Dynamicweb.Rendering
@using Dynamicweb.Frontend
@using Dynamicweb.Ecommerce.Frontend

@if(Model.Orders.Select(o => o.Price.CurrencyCode).Distinct().Count() == 1)
{
    <div class="fs-3 fw-bold text-price">
        @((Model?.Orders?.Sum(o => o.Price.Price) ?? 0).ToString("C"))
    </div>
}
else 
{
    <div class="fs-3 fw-bold">-</div>
    <div class="fs-8 lh-sm text-muted">@Translate("Cannot display total in multiple currencies")</div>
}