@inherits Dynamicweb.Rendering.ViewModelTemplate<ParagraphViewModel>
@using Dynamicweb.Frontend

@{
	string title = Model?.Item?.GetString("Title") ?? string.Empty;
}

<header class="hstack gap-3 mb-4">
	<h1 class="h4 mb-0">@(string.IsNullOrEmpty(title) ? Translate("Dashboard") : title)</h1>
</header>

<div class="row g-3" id="swift-dashboard-widgets">

	<div class="col">
		<div class="card h-100">
			<div class="card-body">
				<div class="hstack gap-3 mb-2">
					<div class="d-grid p-2 rounded-2" style="background-color: color-mix(in srgb, var(--bs-blue) 10%, transparent);">
						<span class="icon fs-5" style="color: var(--bs-blue);">@ReadFile("/Files/Images/Icons/cube.svg")</span>
					</div>
                    <span class="fs-7 fw-semibold text-body-secondary">@Translate("Open orders")</span>
				</div>
                <span class="fs-3 fw-bold lh-1" data-dashboard-count="orders">
                    <span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>
                </span>
			</div>
		</div>
	</div>

	<div class="col">
		<div class="card h-100">
			<div class="card-body">
				<div class="hstack gap-3 mb-2">
					<div class="d-grid p-2 rounded-2" style="background-color: color-mix(in srgb, var(--bs-orange) 10%, transparent);">
						<span class="icon fs-5" style="color: var(--bs-orange);">@ReadFile("/Files/Images/Icons/file-lines.svg")</span>
					</div>
                    <span class="fs-7 fw-semibold text-body-secondary">@Translate("Pending quotes")</span>
				</div>
                <span class="fs-3 fw-bold lh-1" data-dashboard-count="quotes">
                    <span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>
                </span>
			</div>
		</div>
	</div>

    <div class="col">
		<div class="card h-100">
			<div class="card-body">
				<div class="hstack gap-3 mb-2">
					<div class="d-grid p-2 rounded-2 bg-success bg-opacity-10">
						<span class="icon fs-5 text-success">@ReadFile("/Files/Images/Icons/dollar.svg")</span>
					</div>
                    <span class="fs-7 fw-semibold text-body-secondary">@Translate("Total spent")</span>
				</div>
                <span class="fs-3 fw-bold lh-1" data-dashboard-count="total-spent">
                    <span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>
                </span>
			</div>
		</div>
	</div>

	<div class="col">
		<div class="card h-100">
			<div class="card-body">
				<div class="hstack gap-3 mb-2">
					<div class="d-grid p-2 rounded-2" style="background-color: color-mix(in srgb, var(--bs-purple) 10%, transparent);">
						<span class="icon fs-5" style="color: var(--bs-purple);">@ReadFile("/Files/Images/Icons/cart-shopping.svg")</span>
					</div>
					<span class="fs-7 fw-semibold text-body-secondary">@Translate("Active carts")</span>
				</div>
                <span class="fs-3 fw-bold lh-1" data-dashboard-count="carts">
                    <span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>
                </span>
			</div>
		</div>
	</div>

</div>

<script>
	(async function () {
		var countEls = {
			orders: document.querySelector('[data-dashboard-count="orders"]'),
			quotes: document.querySelector('[data-dashboard-count="quotes"]'),
			carts: document.querySelector('[data-dashboard-count="carts"]'),
            totalSpent: document.querySelector('[data-dashboard-count="total-spent"]')
		};

		function setCount(key, value) {
			if (countEls[key]) {
				countEls[key].textContent = value;
			}
		}

		function setError() {
			Object.keys(countEls).forEach(function (key) {
				setCount(key, '--');
			});
		}

		try {
			var tokenRes = await fetch('/dwapi/users/token', {
				method: 'POST',
				credentials: 'include'
			});

			if (!tokenRes.ok) {
				setError();
				return;
			}

			var tokenData = await tokenRes.json();
			var headers = { 'Authorization': 'Bearer ' + tokenData.token };

			var ordersRes = await fetch('/dwapi/ecommerce/orders/search?Type=order&PageSize=999', { headers: headers });
            var quotesRes = await fetch('/dwapi/ecommerce/orders/search?Type=quote&PageSize=999', { headers: headers });
			var cartsRes = await fetch('/dwapi/ecommerce/carts', { headers: headers });
			var totalSpentRes = await fetch('/dwapi/ecommerce/orders/search?Type=order&PageSize=999', { headers: headers });

			if (ordersRes.ok) {
				var ordersData = await ordersRes.json();
				var orders = ordersData.orders?.length || 0;
				setCount('orders', orders);
			}

			if (quotesRes.ok) {
				var quotesData = await quotesRes.json();
				var quotes = quotesData.orders?.length || 0;
				setCount('quotes', quotes);
			}

			if (cartsRes.ok) {
				var cartsData = await cartsRes.json();
				var cartCount = cartsData.length || 0;
				setCount('carts', cartCount);
			}

			if (totalSpentRes.ok) {
				var totalSpentData = await totalSpentRes.json();
				var totalSpent = 0;
				if (Array.isArray(totalSpentData.orders)) {
					for (var i = 0; i < totalSpentData.orders.length; i++) {
						var order = totalSpentData.orders[i];
						if (order.price && typeof order.price.price === 'number') {
							totalSpent += order.price.price;
						}
					}
				}
				setCount('totalSpent', totalSpent.toLocaleString(undefined, { style: 'currency', currency: '@(Dynamicweb.Ecommerce.Common.Context.Currency?.Code ?? "USD")' }));
			}
		} catch (e) {
			setError();
		}
	})();
</script>
