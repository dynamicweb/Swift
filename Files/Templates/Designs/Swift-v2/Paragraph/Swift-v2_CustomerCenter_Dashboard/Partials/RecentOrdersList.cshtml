@inherits ViewModelTemplate<OrderListViewModel>
@using Dynamicweb.Rendering
@using Dynamicweb.Ecommerce.Frontend
@using Dynamicweb.Frontend

@{
    var ordersBaseUrl = Dynamicweb.Context.Current?.Request.QueryString.Get("ordersBaseUrl") ?? null;
}

<div class="list-group list-group-flush">
    @foreach (var order in Model.Orders)
    {
        <a class="list-group-item list-group-item-action px-0 py-3 border-start-0 border-end-0 rounded-0 d-flex flex-wrap align-items-center gap-2 gap-sm-3 text-decoration-none text-body"
            href="@(ordersBaseUrl)?OrderId=@(order.Id)"
            tabindex="@(ordersBaseUrl is not null ? 0 : -1)"
            aria-disabled="@(ordersBaseUrl is not null)"
        >
            <div class="flex-grow-1 min-w-0">
                <div class="fw-semibold text-body">#@(order.Id)</div>
                <div class="fs-8 text-body-secondary text-truncate">
                    @(order.CreatedAt.ToString(Pageview?.Area?.CultureInfo?.DateTimeFormat?.ShortDatePattern ?? "dd/MM/yyyy"))
                    <span class="text-body-secondary">· @(order.OrderLines.Count) @(order.OrderLines.Count == 1 ? @Translate("item") : @Translate("items"))</span>
                </div>
            </div>
            <div class="ms-sm-auto">
                <span class="badge rounded-pill bg-secondary-subtle text-secondary" style="@(order.TryGetOrderState(out var state) ? $"background-color: color-mix(in srgb, {state.StateColor?.Hex} 20%, transparent) !important; color: {state.StateColor?.Hex} !important" : null)">@(order.StateName)</span>
            </div>
            <div class="text-price fs-7 fw-semibold text-price ms-auto">@(order.Price.PriceFormatted)</div>
        </a>
    }
</div>