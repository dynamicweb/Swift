@inherits Dynamicweb.Rendering.ViewModelTemplate<ParagraphViewModel>
@using Dynamicweb.Frontend

@{
    var widgetTitle = Model?.Item?.GetString("Title") ?? Translate("Recent orders");
    var ordersBaseUrl = Model?.Item?.TryGetLink("OrdersPage", out var ordersPage) ?? false ? ordersPage.Url : null;
}

<div class="card">
    <div class="card-body">
        <div class="hstack gap-3 mb-3">
            <div class="hstack gap-3 flex-grow-1">
                <div class="d-grid p-2 rounded-2" style="background-color: color-mix(in srgb, var(--bs-blue) 10%, transparent);">
                    <span class="icon fs-5" style="color: var(--bs-blue);">@ReadFile("/Files/Images/Icons/cube.svg")</span>
                </div>
                <h2 class="h6 mb-0 fw-semibold">@(widgetTitle)</h2>
            </div>
            @if (ordersBaseUrl is not null)
            {
                <a class="fs-8 fw-semibold text-decoration-none text-body-secondary text-decoration-underline-hover" href="@ordersBaseUrl">@Translate("View all") →</a>
            }
        </div>
        <div id="swift-recent-orders-@(Model?.ID)"
            hx-get="/dwapi/ecommerce/orders/search?Type=order&PageSize=5&Page=1&SortBy=CreatedAt&SortOrder=Desc" 
            hx-headers='{"x-dw-template": "/Designs/Swift-v2/Paragraph/Swift-v2_CustomerCenter_Dashboard/Partials/RecentOrdersList.cshtml", "accept": "text/html"}'
            hx-vals='{"ordersBaseUrl": "@(ordersBaseUrl)"}'
            hx-ext="swift-auth"
            hx-trigger="swift:load once" 
            hx-swap="innerHTML">
            <div class="spinner-border spinner-border-sm" role="status">
                <span class="visually-hidden">Loading...</span>
            </div>
        </div>
    </div>
</div>

<script>
    (function () {
        var widget = document.getElementById('swift-recent-orders-@(Model?.ID)');
        var auth;

        if (!widget || !window.htmx) {
            return;
        }

        auth = window.swiftHtmxAuth = window.swiftHtmxAuth || {
            token: null,
            tokenPromise: null,
            ensureToken: function () {
                if (this.token) {
                    return Promise.resolve(this.token);
                }

                if (!this.tokenPromise) {
                    this.tokenPromise = fetch('/dwapi/users/token', {
                        method: 'POST',
                        credentials: 'include'
                    }).then(function (response) {
                        if (!response.ok) {
                            throw new Error('Unable to fetch auth token.');
                        }

                        return response.json();
                    }).then(function (data) {
                        auth.token = data.token;
                        return auth.token;
                    }).catch(function () {
                        auth.tokenPromise = null;
                        return null;
                    });
                }

                return this.tokenPromise;
            }
        };

        if (!window.swiftHtmxAuthExtensionDefined) {
            htmx.defineExtension('swift-auth', {
                onEvent: function (name, event) {
                    if (name !== 'htmx:configRequest' || !auth.token) {
                        return;
                    }

                    event.detail.headers.Authorization = 'Bearer ' + auth.token;
                }
            });

            window.swiftHtmxAuthExtensionDefined = true;
        }

        var loadRecentOrders = async function () {
            var token = await auth.ensureToken();

            if (!token) {
                return;
            }

            widget.dispatchEvent(new CustomEvent('swift:load'));
        };

        if (document.readyState === 'loading') {
            document.addEventListener('DOMContentLoaded', loadRecentOrders, { once: true });
            return;
        }

        loadRecentOrders();
    })();
</script>