@inherits Dynamicweb.Rendering.ViewModelTemplate<Dynamicweb.Frontend.Navigation.NavigationTreeViewModel>
@using Dynamicweb.Frontend
@using Dynamicweb.Frontend.Navigation

@if (!Model.Nodes.Any()) return;

<div class="offcanvas-header offcanvas-animate-in z-2 bg-body pe-4" style="grid-area: Header;">
    <button type="button" class="btn icon-3 p-2" @@click="$dispatch('close-offcanvas');">
        @ReadFile("/Files/Images/Icons/chevron-left.svg")
    </button>
    <button type="button" class="btn-close" data-bs-dismiss="offcanvas"></button>
</div>
<div class="offcanvas-body offcanvas-animate-in z-2 bg-body px-4" style="grid-area: Body;">

    <ul class="navbar-nav">
        @foreach (var node in Model.Nodes.Where(n => n.ShowInMenu))
        {
            var isEcom = node.IsEcommerceGroup();

            <li class="hstack justify-content-between">
                <a href="@(node.IsClickable ? node.Link : null)" class="flex-fill text-decoration-none @(node.Level.Equals(2) ? null : "text-body text-opacity-75")">
                    <span>@node.Name</span>
                </a>
                
                @if(node.Nodes.Where(n => n.ShowInMenu).Any())
                {
                    var areaId = Dynamicweb.Content.Services.Pages.GetPage(node.PageId)?.AreaId;
                    var endpoint = $"/dwapi/frontend/navigations/{areaId}?ExpandMode=all&RootPageId={node.PageId}";
                    var template = "Designs/Swift-v2/Paragraph/Swift-v2_OffCanvasMenu/Layouts/Menu.cshtml";

                    <button type="button" class="btn icon-3 py-2 ps-4 pe-0"
                        hx-trigger="click"
                        hx-get="@(endpoint)" 
                        hx-headers='
                        {
                            "Accept": "text/html",
                            "x-dw-template": "@(template)"
                        }'
                        hx-target="closest [data-swift-offcanvas-menu]"
                        hx-swap="beforeend"
                    >
                        @ReadFile("/Files/Images/Icons/chevron-right.svg")
                    </button>
                }
            </li>
        }
    </ul>

<div>